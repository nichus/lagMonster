{
  "name": "lagmonster",
  "version": "1.0.1",
  "description": "The Lag Monster eats YOU!",
  "main": "lag.js",
  "scripts": {
    "pm2": "pm2 start processes.json --no-daemon",
    "test": "nodemon lag.js",
    "start": "node .",
    "lint": "eslint .",
    "dev": "node . | pino-pretty -i pid,hostname -t 'yyyy-mm-dd HH:MM:ss'",
    "daemon": "nodemon lag.js | pino-pretty -cl -i pid,hostname -t 'yyyy-mm-ddTHH:MM:ss.l' --minimumLevel 'debug'"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "nodemonConfig": {
    "ignore": [
      "data"
    ]
  },
  "devDependencies": {
    "eslint": "^10.7.0",
    "nodemon": "^3.1.14"
  },
  "dependencies": {
    "@discordjs/rest": "^2.6.2",
    "discord.js": "^14.27.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pm2": "^7.0.3"
  }
}
